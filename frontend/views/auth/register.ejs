<%- include('../partials/header') %>
<div class="auth-box">
    <h2>회원가입</h2>
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form action="/auth/register" method="POST">
        <div class="form-group">
            <label>아이디</label>
            <input type="text" name="username" placeholder="아이디를 입력하세요" required>
        </div>
        <div class="form-group">
            <label>이메일</label>
            <input type="email" name="email" placeholder="이메일을 입력하세요" required>
        </div>
        <div class="form-group">
            <label>비밀번호 <small>(8자 이상)</small></label>
            <input type="password" name="password" placeholder="비밀번호를 입력하세요" required>
        </div>
        <div class="form-group">
            <label>비밀번호 확인</label>
            <input type="password" name="password_confirm" placeholder="비밀번호를 다시 입력하세요" required>
        </div>
        <button type="submit" class="btn btn-primary btn-full">회원가입</button>
    </form>
    <p class="auth-link">이미 계정이 있으신가요? <a href="/auth/login">로그인</a></p>
</div>
<%- include('../partials/footer') %>
